---
name: "{{ project_name }}_{{ username }}_login_node"

services:
  # example service named 'login_node'
  # create additional services
  login_node:
    build:
      context: {{ paths__modules }}/{{ login_node_module|default("ssh_ubi") }}
      dockerfile: Containerfile
    image: fit-ctf/{{ login_node_module|default("ssh_ubi") }}:latest
    restart: unless-stopped
    # use shared or private mode
    networks:
      {{ network_map__shared }}:
      {{ network_map__private }}:
    # Host bind from enrollment; students use forwarded_port when it differs (NAT / edge)
    ports:
      - "{{ container_port }}:22"
    labels:
      fit_ctf.ssh.container_port: "{{ container_port }}"
      fit_ctf.ssh.forwarded_port: "{{ forwarded_port }}"
    environment: {}
    volumes:
      - "{{ login_node__volume_map__home }}:/home/user"
      - "{{ login_node__volume_map__shadow }}:/etc/shadow"

# set networks as external
networks:
  {{ network_map__shared }}:
    external: true
  {{ network_map__private }}:
    external: true
